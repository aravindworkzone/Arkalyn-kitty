# ---- Frontend environment variables ----
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# Vite only exposes vars prefixed with VITE_ to the client bundle.

# Base URL of the backend API (include the /api suffix).
# Production: point this at the deployed backend, e.g. https://your-backend.onrender.com/api
VITE_API_URL=http://localhost:5000/api

# Razorpay public Key ID (the same value as the backend's RAZORPAY_KEY_ID).
# Safe to expose to the browser — it only identifies the merchant account. The
# Key Secret must NEVER be placed here. Leave blank to hide the checkout flow.
VITE_RAZORPAY_KEY_ID=rzp_test_your-key-id
