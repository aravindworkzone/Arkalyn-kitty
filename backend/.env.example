# ---- Backend environment variables ----
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# The server validates the required vars on startup (config/env.ts -> validateEnv).

# Port the Express server listens on.
PORT=5000

# MongoDB Atlas connection string. Use a dedicated DB user with a strong password.
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/Expense-Tracker

# JWT signing secrets. Generate strong unique values, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ACCESS_TOKEN_SECRET=<64-hex-char-random-string>
REFRESH_TOKEN_SECRET=<64-hex-char-random-string>

# Token lifetimes (optional — defaults shown).
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Allowed origin for CORS + cookie behaviour. Set to the deployed frontend URL in production.
FRONTEND_URL=http://localhost:3000

# Resend (https://resend.com) HTTP API for transactional email (password reset).
# Free tier: 3,000 emails/month, 100/day, no credit card.
#   1. Create an account, then create an API key at resend.com/api-keys.
#   2. Paste it as RESEND_API_KEY below.
#   3. Until you verify a sending domain at resend.com/domains, leave
#      RESEND_FROM blank — sends will go from "onboarding@resend.dev" which
#      works out of the box but lands in the "promotions/spam" tab for some
#      providers. Once verified, set e.g. RESEND_FROM="Arkalyn-Kitty <noreply@yourdomain.com>".
# Leave RESEND_API_KEY blank to disable email; the reset link is logged to the
# server console instead.
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM=

# Razorpay (https://razorpay.com) — subscription billing. Optional: leave blank
# to disable payments (order creation returns 503; the rest of the app works).
#   1. Sign up, switch to Test mode, and copy the Key ID + Key Secret from
#      Settings -> API Keys. Test keys start with "rzp_test_".
#   2. RAZORPAY_KEY_ID is also exposed to the browser as VITE_RAZORPAY_KEY_ID
#      (it is public/safe). RAZORPAY_KEY_SECRET stays server-only.
#   3. (Optional) Create a webhook at Settings -> Webhooks pointing to
#      <backend>/api/subscription/webhook, subscribe to "payment.captured", and
#      paste the signing secret as RAZORPAY_WEBHOOK_SECRET for server-to-server
#      confirmation in addition to the browser callback.
RAZORPAY_KEY_ID=rzp_test_your-key-id
RAZORPAY_KEY_SECRET=your-key-secret
RAZORPAY_WEBHOOK_SECRET=

# Runtime mode. Set to `production` on the deployed host (enables secure cookies).
NODE_ENV=development
